# ─── Anthropic (required) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Shopify ─────────────────────────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_ACCESS_TOKEN=shpat_...
SHOPIFY_APP_CLIENT_ID=
SHOPIFY_APP_CLIENT_SECRET=
SHOPIFY_API_VERSION=2024-10

# ─── Printify (print-on-demand — get key at printify.com/app/account/api-access)
PRINTIFY_API_KEY=
# Optional — Awon auto-detects the first shop if blank
PRINTIFY_SHOP_ID=

# ─── TikTok Shop API (from partner.tiktokshop.com) ───────────────────────────
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_SHOP_ACCESS_TOKEN=
TIKTOK_SHOP_ID=
TIKTOK_WAREHOUSE_ID=

# ─── TikTok Content Posting API (from developers.tiktok.com) ─────────────────
# OAuth access token for @the.rival.is.me — scope: video.upload, video.publish
TIKTOK_CONTENT_ACCESS_TOKEN=

# ─── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_PASSWORD=therivalisme

# ─── Railway (auto-set, leave blank locally) ──────────────────────────────────
PORT=3000

# ─── Awon behavior ────────────────────────────────────────────────────────────
# How often Awon runs a full cycle (cron syntax — default every 8 hours)
CYCLE_CRON=0 */8 * * *

# Starting budget Awon can work with for ad spend / tools (USD)
STARTING_BUDGET_USD=50
